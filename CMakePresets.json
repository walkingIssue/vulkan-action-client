{
  "version": 5,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "msvc-base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "environment": {
        "VCPKG_ROOT": "${sourceDir}/../tools/vcpkg"
      },
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/../tools/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "msvc-debug",
      "displayName": "MSVC Debug",
      "inherits": "msvc-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "msvc-release",
      "displayName": "MSVC Release",
      "inherits": "msvc-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "msvc-debug",
      "configurePreset": "msvc-debug"
    },
    {
      "name": "msvc-release",
      "configurePreset": "msvc-release"
    }
  ],
  "testPresets": [
    {
      "name": "msvc-debug",
      "displayName": "MSVC Debug Tests",
      "configurePreset": "msvc-debug",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    },
    {
      "name": "msvc-debug-unit",
      "displayName": "MSVC Debug Unit Tests",
      "inherits": "msvc-debug",
      "filter": {
        "include": {
          "label": "unit"
        }
      }
    },
    {
      "name": "msvc-debug-network",
      "displayName": "MSVC Debug Network Tests",
      "inherits": "msvc-debug",
      "filter": {
        "include": {
          "label": "network"
        }
      }
    },
    {
      "name": "msvc-debug-e2e",
      "displayName": "MSVC Debug E2E Tests",
      "inherits": "msvc-debug",
      "filter": {
        "include": {
          "label": "e2e"
        }
      }
    },
    {
      "name": "msvc-debug-combat",
      "displayName": "MSVC Debug Combat Tests",
      "inherits": "msvc-debug",
      "filter": {
        "include": {
          "label": "combat"
        }
      }
    },
    {
      "name": "msvc-debug-characterization",
      "displayName": "MSVC Debug Characterization Tests",
      "inherits": "msvc-debug",
      "filter": {
        "include": {
          "label": "characterization"
        }
      }
    },
    {
      "name": "msvc-debug-viewer",
      "displayName": "MSVC Debug Viewer Smoke Tests",
      "inherits": "msvc-debug",
      "filter": {
        "include": {
          "label": "viewer"
        }
      }
    },
    {
      "name": "msvc-release",
      "displayName": "MSVC Release Tests",
      "configurePreset": "msvc-release",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    }
  ]
}
